# ─── SMTP Configuration ───────────────────────────────────────────────────────
# For Gmail: use an App Password (not your regular password).
# Enable 2-Factor Auth on Gmail → Google Account → Security → App Passwords → Mail.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465, false for 587 (STARTTLS)

SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # 16-char Gmail App Password

# ─── Recipients ───────────────────────────────────────────────────────────────
RECIPIENT_EMAIL=deepaksingh@lumorasolar.org
SENDER_NAME=Lumora Solar Website

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
